#!/usr/bin/env php

<?php

require __DIR__ . '/../vendor/autoload.php';

use FQL\Cli\Application as FqlApplication;
use FQL\Cli\Command\QueryCommand;
use FQL\Cli\Command\SelfUpdateCommand;
use Symfony\Component\Console\Application;

$application = new Application(FqlApplication::NAME, FqlApplication::VERSION);
$application->addCommand(new QueryCommand());
$application->addCommand(new SelfUpdateCommand());
$application->setDefaultCommand('fiquela-cli');
$application->run();
